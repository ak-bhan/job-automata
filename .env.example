# JobAutomata environment configuration
# Copy this file to .env and fill in your values

# Server
HOST=127.0.0.1
PORT=8000

# Database
DB_PATH=db.sqlite

# Resume storage
RESUME_DIR=resumes

# LLM integration (optional — not used in v0.1)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3
